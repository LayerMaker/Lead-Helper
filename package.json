{
  "name": "lead-helper-shell",
  "private": true,
  "version": "0.0.0",
  "type": "module",
  "scripts": {
    "dev": "vite",
    "build": "vite build",
    "lint": "eslint .",
    "postinstall": "playwright install chromium",
    "preview": "vite preview",
    "start": "node server.mjs",
    "deploy:render": "powershell -ExecutionPolicy Bypass -File ./scripts/deploy-render.ps1",
    "deploy:render:current": "powershell -ExecutionPolicy Bypass -File ./scripts/deploy-render.ps1 -CurrentCommit",
    "ship:render": "npm run build && npm run deploy:render:current",
    "data:build": "node ./scripts/build-dealership-dataset.mjs",
    "data:import": "node ./scripts/import-dealership-job.mjs",
    "data:collect": "node ./scripts/collect-osm-candidates.mjs",
    "data:collect:wandsworth:osm": "node ./scripts/collect-osm-candidates.mjs ./data/collector-jobs/wandsworth.osm.json",
    "data:collect:london:newcar": "node ./scripts/collect-osm-candidates.mjs ./data/collector-jobs/london-newcar.discovery.json",
    "data:refresh:wandsworth": "node ./scripts/import-dealership-job.mjs ./data/import-jobs/wandsworth.sample.json && npm run data:build",
    "data:refresh:chiswick": "node ./scripts/import-dealership-job.mjs ./data/import-jobs/chiswick.sample.json && npm run data:build",
    "data:refresh:wandsworth:osm": "node ./scripts/collect-osm-candidates.mjs ./data/collector-jobs/wandsworth.osm.json && node ./scripts/import-dealership-job.mjs ./data/import-jobs/wandsworth.osm.generated.json && npm run data:build"
  },
  "dependencies": {
    "@turf/buffer": "^7.3.5",
    "@turf/center-of-mass": "^7.3.5",
    "@turf/convex": "^7.3.5",
    "@turf/helpers": "^7.3.5",
    "express": "^5.2.1",
    "html2canvas": "^1.4.1",
    "jspdf": "^4.2.1",
    "leaflet": "^1.9.4",
    "playwright-chromium": "^1.61.0",
    "react": "^19.2.6",
    "react-dom": "^19.2.6",
    "react-leaflet": "^5.0.0",
    "react-router-dom": "^7.17.0"
  },
  "devDependencies": {
    "@eslint/js": "^10.0.1",
    "@types/react": "^19.2.14",
    "@types/react-dom": "^19.2.3",
    "@vitejs/plugin-react": "^6.0.1",
    "eslint": "^10.3.0",
    "eslint-plugin-react-hooks": "^7.1.1",
    "eslint-plugin-react-refresh": "^0.5.2",
    "globals": "^17.6.0",
    "vite": "^8.0.12"
  }
}
